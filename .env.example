# Database (Supabase)
DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DB"
DIRECT_URL="postgresql://USER:PASS@HOST:PORT/DB"

# NextAuth
NEXTAUTH_URL="http://localhost:3003"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# WaveSpeed (primary AI provider)
WAVESPEED_KEY="your-wavespeed-key"

# Atlas Cloud (fallback provider)
ATLAS_KEY="your-atlas-key"

# Alibaba Cloud (Qwen/Wan direct)
ALIBABA_KEY="your-alibaba-key"
ALIBABA_WORKSPACE_ID="your-workspace-id"

# Stripe
STRIPE_SECRET_KEY="sk_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe recurring subscription price IDs
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_STUDIO="price_..."
STRIPE_PRICE_PRO="price_..."

# LLM Provider (for AI agents/orchestrator)
OPENROUTER_KEY=""

# Stripe credit pack price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_CREDITS_500="price_..."
STRIPE_PRICE_CREDITS_1000="price_..."
STRIPE_PRICE_CREDITS_2500="price_..."
STRIPE_PRICE_CREDITS_5000="price_..."
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_500="price_..."
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_1000="price_..."
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_2500="price_..."
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_5000="price_..."

# Cron secret for automation routes
CRON_SECRET="your-cron-secret"